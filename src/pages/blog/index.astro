---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sections, buttons, emptyStates } from "../../data/site";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const formatDate = (iso: string) => {
  if (!iso) return "";
  return new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(new Date(iso));
};
---

<BaseLayout
  title="Blog | Rainard Distor"
  description="Writing on AI governance and digital policy in Southeast Asia, with a focus on who gets left out of the conversation."
  canonicalPath="/blog"
>
  <div class="blog-index shell">
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {buttons.home}
    </a>

    <header class="blog-head">
      <p class="eyebrow eyebrow--accent">{sections.blog.eyebrow}</p>
      <h1 class="blog-title">{sections.blog.heading}</h1>
      <p class="blog-intro">{sections.blogIndex.intro}</p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty">{emptyStates.noPosts}</p>
    ) : (
      <ol class="post-list">
        {posts.map((post, i) => {
          const slug = post.data.slug || post.id;
          return (
            <li class="post-item" data-reveal>
              <a href={`/blog/${slug}`} class="post-link">
                <div class="post-aside">
                  <span class="post-index">{String(i + 1).padStart(2, "0")}</span>
                  <div class="post-metacol">
                    {post.data.category && <span class="eyebrow eyebrow--accent">{post.data.category}</span>}
                    <span class="eyebrow post-date">{formatDate(post.data.date)}</span>
                  </div>
                </div>
                <div class="post-main">
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
                  <span class="post-read">
                    {buttons.read}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  .blog-index {
    max-width: 68rem;
    padding-top: 8rem;
    padding-bottom: var(--space-2xl);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3-solid);
    margin-bottom: 3.5rem;
    transition: color 0.25s ease;
  }
  .back-link:hover { color: var(--accent-ink); }

  .blog-head {
    padding-bottom: 3rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--line-strong);
  }
  .blog-title {
    font-family: var(--font-display);
    font-size: var(--step-5);
    font-weight: 360;
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: var(--ink);
    margin: 0.75rem 0 1.5rem;
    text-transform: none;
    font-variation-settings: "opsz" 120;
  }
  .blog-intro {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 48ch;
  }

  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-item { border-bottom: 1px solid var(--line); }
  .post-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 2.5rem 0;
  }
  .post-aside { display: flex; align-items: baseline; gap: 1.25rem; }
  .post-index {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.1em;
    color: var(--ink-3-solid);
  }
  .post-metacol { display: flex; flex-direction: column; gap: 0.35rem; }
  .post-date { color: var(--ink-3-solid); }
  .post-title {
    font-family: var(--font-display);
    font-size: var(--step-4);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.98;
    color: var(--ink);
    margin: 0 0 0.9rem;
    transition: color 0.3s ease;
    font-variation-settings: "opsz" 110;
    max-width: 22ch;
  }
  .post-link:hover .post-title { color: var(--accent-ink); }
  .post-excerpt {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 56ch;
    margin-bottom: 1.1rem;
  }
  .post-read {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .post-read svg { transition: transform 0.3s ease; }
  .post-link:hover .post-read svg { transform: translateX(4px); }
  .blog-empty { font-family: var(--font-body); color: var(--ink-3-solid); }

  @media (min-width: 768px) {
    .post-link { grid-template-columns: 15rem 1fr; gap: 2.5rem; align-items: start; }
    .post-aside { flex-direction: column; gap: 0.75rem; }
  }
</style>
