---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sections, buttons, emptyStates } from "../../data/site";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const formatDate = (iso: string) => {
  if (!iso) return "";
  return new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(new Date(iso));
};
---

<BaseLayout
  title="Blog | Rainard Distor"
  description="Writing on AI governance and digital policy in Southeast Asia, with a focus on who gets left out of the conversation."
  canonicalPath="/blog"
>
  <div class="blog-index shell">
    <a href="/" class="back-link mono">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {buttons.home}
    </a>

    <header class="blog-head">
      <p class="eyebrow eyebrow--accent">writing</p>
      <h1 class="blog-title mono">{sections.blog.heading}</h1>
      <p class="blog-intro">{sections.blogIndex.intro}</p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-empty mono">{emptyStates.noPosts}</p>
    ) : (
      <ol class="post-list">
        {posts.map((post) => {
          const slug = post.data.slug || post.id;
          return (
            <li class="post-item" data-reveal>
              <a href={`/blog/${slug}`} class="post-link">
                <div class="post-aside mono">
                  {post.data.category && <span class="post-cat">{post.data.category}</span>}
                  <span class="post-date">{formatDate(post.data.date)}</span>
                </div>
                <div class="post-main">
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
                  <span class="post-read mono">
                    {buttons.read}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6" />
                    </svg>
                  </span>
                </div>
                <span class="post-arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6"/></svg>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</BaseLayout>

<style>
  .blog-index {
    max-width: 60rem;
    padding-top: clamp(2.5rem, 6vw, 4rem);
    padding-bottom: var(--space-2xl);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: var(--fg-3);
    margin-bottom: 3rem;
    transition: color 0.25s ease;
  }
  .back-link:hover { color: var(--fg); }

  .blog-head {
    padding-bottom: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .blog-title {
    font-family: var(--font-mono);
    font-size: var(--step-4);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--fg);
    margin: 0.75rem 0 1.25rem;
    text-transform: none;
  }
  .blog-intro {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--fg-3);
    max-width: 52ch;
  }

  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-item { border-bottom: 1px solid var(--line); }
  .post-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "aside arrow" "main arrow";
    gap: 0.75rem 1rem;
    padding: 2.25rem 0;
    align-items: start;
  }
  .post-aside {
    grid-area: aside;
    display: flex;
    gap: 1rem;
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    color: var(--fg-3);
  }
  .post-cat { color: var(--accent-fg); }
  .post-main { grid-area: main; }
  .post-title {
    font-family: var(--font-body);
    font-size: var(--step-3);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--fg);
    margin: 0 0 0.75rem;
    transition: color 0.25s ease;
    max-width: 26ch;
  }
  .post-link:hover .post-title { color: var(--accent-fg); }
  .post-excerpt {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--fg-3);
    max-width: 60ch;
    margin-bottom: 1rem;
  }
  .post-read {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--fg-2);
  }
  .post-read svg { transition: transform 0.25s ease; }
  .post-link:hover .post-read svg { transform: translateX(3px); }
  .post-arrow {
    grid-area: arrow;
    align-self: center;
    color: var(--fg-3);
    transition: color 0.25s ease, transform 0.25s ease;
  }
  .post-link:hover .post-arrow { color: var(--fg); transform: translateX(4px); }
  .blog-empty { color: var(--fg-3); }

  @media (min-width: 768px) {
    .post-link {
      grid-template-columns: 11rem 1fr auto;
      grid-template-areas: "aside main arrow";
      gap: 2.5rem;
    }
    .post-aside { flex-direction: column; gap: 0.5rem; padding-top: 0.35rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-link:hover .post-arrow,
    .post-link:hover .post-read svg { transform: none; }
  }
</style>
