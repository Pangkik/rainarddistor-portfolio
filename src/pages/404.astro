---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
  canonicalPath="/404"
>
  <section class="notfound">
    <div class="notfound-inner">
      <p class="eyebrow eyebrow--accent">404</p>
      <h1 class="notfound-title mono">Oops! Page not found</h1>
      <a href="/" class="btn-primary notfound-cta">Return to Home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: 70svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    background: var(--bg);
  }
  .notfound-inner { text-align: center; max-width: 30rem; }
  .notfound-title {
    font-family: var(--font-mono);
    font-size: var(--step-3);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--fg);
    margin: 1rem 0 2.25rem;
  }
  .notfound-cta { margin-top: 0.5rem; }
</style>
