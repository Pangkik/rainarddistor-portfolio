---
import { Image } from "astro:assets";
import { heroName, heroLabel, heroParagraph, contactLinks } from "../../data/site";
import portrait from "../../assets/portfolio/CYBERCON Day 3-142.jpeg";
---

<section class="hero">
  <div class="shell">
    <div class="hero-grid">
      <div class="hero-lead">
        <p class="hero-tag mono">{heroLabel}</p>

        <h1 class="hero-name mono">
          <span>{heroName[0]}</span>
          <span>{heroName[1]}</span>
        </h1>

        <p class="hero-para">{heroParagraph}</p>

        <div class="hero-links">
          <a href={contactLinks.linkedIn} target="_blank" rel="noopener noreferrer" class="text-link">
            linkedin
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M9 7h8v8"/></svg>
          </a>
          <a href={contactLinks.twitter} target="_blank" rel="noopener noreferrer" class="text-link">
            x
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M9 7h8v8"/></svg>
          </a>
          <a href={`mailto:${contactLinks.email}`} class="text-link">
            email
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M9 7h8v8"/></svg>
          </a>
        </div>
      </div>

      <figure class="hero-portrait">
        <Image
          src={portrait}
          alt="Rainard Distor at the ASEAN-IPR Regional Conference on Cybersecurity 2025"
          widths={[320, 520]}
          sizes="(min-width: 768px) 18rem, 60vw"
          loading="eager"
        />
      </figure>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .hero-tag {
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--accent-fg);
    letter-spacing: 0.01em;
    text-transform: none;
    max-width: 40ch;
    margin-bottom: 1.5rem;
  }
  .hero-name {
    font-size: clamp(2.6rem, 1.2rem + 7vw, 5.5rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin: 0 0 1.75rem;
  }
  .hero-name span { display: block; }
  .hero-para {
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--fg-2);
    max-width: 46ch;
    margin-bottom: 2rem;
  }
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.75rem;
  }
  .hero-portrait {
    margin: 0;
    order: -1;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: var(--bg-3);
    width: min(16rem, 70%);
    aspect-ratio: 4 / 5;
  }
  .hero-portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr auto;
      gap: clamp(2.5rem, 6vw, 5rem);
    }
    .hero-portrait { order: 0; width: 17rem; }
  }
</style>
