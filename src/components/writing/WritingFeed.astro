---
import { getCollection } from "astro:content";
import { sections } from "../../data/site";

const allPosts = await getCollection("blog");
const posts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const formatDate = (iso: string) => {
  if (!iso) return "";
  return new Intl.DateTimeFormat("en-US", { year: "numeric", month: "short" }).format(new Date(iso));
};
---

<section id="writing" class="block">
  <div class="shell">
    <div class="sec-head" data-reveal>
      <div>
        <h2 class="sec-title">
          <span class="sec-num">01</span><span class="sec-dash">—</span><span>writing</span>
        </h2>
        <p class="sec-blurb">{sections.blog.blurb}</p>
      </div>
      <a href="/blog" class="sec-all">
        all
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6"/></svg>
      </a>
    </div>

    {posts.length === 0 ? (
      <div class="feed-empty mono">No posts published yet.</div>
    ) : (
      <ol class="feed-list">
        {posts.map((post) => {
          const slug = post.data.slug || post.id;
          return (
            <li class="feed-item" data-reveal>
              <a href={`/blog/${slug}`} class="feed-link">
                <div class="feed-meta mono">
                  {post.data.category && <span class="feed-cat">{post.data.category}</span>}
                  <span class="feed-date">{formatDate(post.data.date)}</span>
                </div>
                <div class="feed-body">
                  <h3 class="feed-title">{post.data.title}</h3>
                  {post.data.excerpt && <p class="feed-excerpt">{post.data.excerpt}</p>}
                </div>
                <span class="feed-arrow" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-6-6 6 6-6 6"/></svg>
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</section>

<style>
  .feed-list { list-style: none; margin: 0; padding: 0; }
  .feed-item { border-top: 1px solid var(--line); }
  .feed-item:last-child { border-bottom: 1px solid var(--line); }
  .feed-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "meta arrow" "body arrow";
    gap: 0.4rem 1rem;
    padding: 1.75rem 0;
    align-items: start;
  }
  .feed-meta {
    grid-area: meta;
    display: flex;
    gap: 1rem;
    font-size: var(--step--2);
    color: var(--fg-3);
    letter-spacing: 0.04em;
  }
  .feed-cat { color: var(--accent-fg); }
  .feed-body { grid-area: body; }
  .feed-title {
    font-family: var(--font-body);
    font-size: var(--step-2);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--fg);
    margin: 0 0 0.5rem;
    transition: color 0.25s ease;
    max-width: 30ch;
  }
  .feed-link:hover .feed-title { color: var(--accent-fg); }
  .feed-excerpt {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--fg-3);
    max-width: 62ch;
  }
  .feed-arrow {
    grid-area: arrow;
    display: inline-flex;
    align-self: center;
    color: var(--fg-3);
    transition: color 0.25s ease, transform 0.25s ease;
  }
  .feed-link:hover .feed-arrow { color: var(--fg); transform: translateX(4px); }
  .feed-empty { padding: 3rem 0; text-align: center; color: var(--fg-3); }

  @media (min-width: 640px) {
    .feed-link {
      grid-template-columns: 9rem 1fr auto;
      grid-template-areas: "meta body arrow";
      gap: 2rem;
    }
    .feed-meta { flex-direction: column; gap: 0.4rem; padding-top: 0.35rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .feed-link:hover .feed-arrow { transform: none; }
  }
</style>
