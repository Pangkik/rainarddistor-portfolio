---
import { Image } from "astro:assets";
import aboutPhoto from "../../assets/about-photo.jpeg";
import studioPhoto from "../../assets/about/Studio.png";
import { sections, about } from "../../data/site";
import { expertiseAreas } from "../../data/expertise";
---

<section id="about" class="about">
  <div class="shell">
    {/* Centered section intro — duna eyebrow-label rhythm */}
    <div class="about-intro" data-reveal>
      <div class="about-rule"></div>
      <p class="eyebrow eyebrow--accent">{sections.about.eyebrow}</p>
      <h2 class="about-heading">{sections.about.heading}</h2>
    </div>

    {/* Alternating block: bio + studio portrait (duna rhythm) */}
    <div class="about-grid">
      <div class="about-bio" data-reveal>
        <div class="about-paras">
          {sections.about.paragraphs.map((para) => (
            <p>{para}</p>
          ))}
        </div>
      </div>

      <div class="about-portraits" data-reveal>
        <figure class="about-figure about-figure--studio">
          <Image src={studioPhoto} alt={about.photoAlt} widths={[360, 560]} sizes="(min-width: 768px) 24rem, 70vw" />
        </figure>
        <figure class="about-figure about-figure--cybercon">
          <Image src={aboutPhoto} alt={about.photoAlt} widths={[280, 440]} sizes="(min-width: 768px) 16rem, 45vw" />
        </figure>
      </div>
    </div>

    {/* Expertise — editorial numbered list, not boxy cards */}
    <div class="about-expertise">
      <ol class="expertise-list">
        {expertiseAreas.map((area, i) => (
          <li class="expertise-item" data-reveal>
            <span class="expertise-index">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h3 class="expertise-title">{area.title}</h3>
              <p class="expertise-desc">{area.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .about {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    background: var(--paper-2);
  }
  .about-intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }
  .about-rule {
    width: 3.5rem;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.75rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .about-heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin: 0.9rem 0 0;
    text-transform: none;
    font-variation-settings: "opsz" 72;
  }
  .about-paras {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    max-width: 46ch;
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.7;
    color: var(--ink-2);
  }

  .about-portraits {
    position: relative;
    display: flex;
    justify-content: center;
    padding-block: 1rem;
  }
  .about-figure {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: var(--paper-3);
  }
  .about-figure :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-figure--studio {
    width: min(22rem, 80%);
    aspect-ratio: 4 / 5;
  }
  .about-figure--cybercon {
    display: none;
    position: absolute;
    width: 11rem;
    aspect-ratio: 3 / 4;
    right: 0;
    bottom: -1.5rem;
    box-shadow: 0 18px 40px -22px rgba(26, 23, 20, 0.45);
  }

  .about-expertise { margin-top: var(--space-2xl); }
  .expertise-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .expertise-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1.25rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--line);
    align-items: start;
  }
  .expertise-item:last-child { border-bottom: 1px solid var(--line); }
  .expertise-index {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.1em;
    color: var(--accent-ink);
    padding-top: 0.35rem;
  }
  .expertise-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 0.4rem;
    text-transform: none;
  }
  .expertise-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 52ch;
  }

  @media (min-width: 768px) {
    .about-grid { grid-template-columns: 1.35fr 1fr; gap: 4.5rem; }
    .about-portraits { justify-content: flex-end; padding-right: 1.5rem; }
    .about-figure--studio { width: 24rem; }
    .about-figure--cybercon { display: block; }
    .expertise-list { grid-template-columns: 1fr 1fr; column-gap: 4rem; }
    .expertise-item { padding: 2rem 0; }
    /* keep top borders continuous across two columns */
    .expertise-item:nth-last-child(2):nth-child(odd) { border-bottom: 1px solid var(--line); }
  }
</style>
