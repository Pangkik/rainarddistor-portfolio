---
import { sections } from "../../data/site";
---

<section id="about" class="block">
  <div class="shell">
    <div class="about" data-reveal>
      <p class="about-eyebrow mono">about</p>
      <div class="about-prose">
        {sections.about.paragraphs.map((para) => (
          <p>{para}</p>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .about-eyebrow {
    font-size: var(--step--2);
    color: var(--fg-3);
    letter-spacing: 0.08em;
    padding-top: 0.4rem;
  }
  .about-prose {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-family: var(--font-body);
    font-size: var(--step-1);
    line-height: 1.7;
    color: var(--fg-2);
    max-width: 60ch;
  }

  @media (min-width: 768px) {
    .about { grid-template-columns: 8rem 1fr; gap: 3rem; }
  }
</style>
