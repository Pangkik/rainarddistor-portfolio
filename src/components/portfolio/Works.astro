---
import { works, categories } from "../../data/works";
import { sections } from "../../data/site";
---

<section id="works" class="block">
  <div class="shell">
    <div class="sec-head" data-reveal>
      <div>
        <h2 class="sec-title">
          <span class="sec-num">02</span><span class="sec-dash">—</span><span>works</span>
        </h2>
        <p class="sec-blurb">{sections.works.blurb}</p>
      </div>
    </div>

    {/* Filters — vanilla JS toggles, all cards visible with no JS */}
    <div class="works-filters" role="group" aria-label="Filter works by category" data-reveal>
      {categories.map((cat, i) => (
        <button
          type="button"
          class:list={["works-filter mono", { "is-active": i === 0 }]}
          data-filter={cat}
          aria-pressed={i === 0 ? "true" : "false"}
        >
          {cat}
        </button>
      ))}
    </div>

    <ol class="works-grid" id="works-grid">
      {works.map((work, i) => (
        <li
          class:list={["work-item", i % 2 === 0 ? "tilt-l" : "tilt-r"]}
          data-category={work.category}
          data-reveal
        >
          <a href={work.link} target="_blank" rel="noopener noreferrer" class="work-card">
            <div class="work-top mono">
              <span class="work-cat">{work.category}</span>
              <span class="work-date">{work.date}</span>
            </div>
            <h3 class="work-title">{work.title}</h3>
            <p class="work-desc">{work.description}</p>
            <span class="work-more mono">
              read
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M9 7h8v8"/></svg>
            </span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .works-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
  .works-filter {
    font-size: var(--step--2);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: var(--fg-3);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .works-filter:hover { color: var(--fg); border-color: var(--line-strong); }
  .works-filter.is-active {
    color: var(--bg);
    background: var(--fg);
    border-color: var(--fg);
  }

  .works-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .work-item[hidden] { display: none; }

  /* Resting tilt that straightens + lifts on hover */
  .work-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1),
                box-shadow 0.4s ease, border-color 0.3s ease;
    transform: rotate(var(--tilt, 0deg));
    will-change: transform;
  }
  .tilt-l { --tilt: -1.2deg; }
  .tilt-r { --tilt: 1.2deg; }
  .work-card:hover {
    transform: rotate(0deg) translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--line-strong);
  }

  .work-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: var(--step--2);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }
  .work-cat { color: var(--accent-fg); }
  .work-date { color: var(--fg-3); }
  .work-title {
    font-family: var(--font-body);
    font-size: var(--step-1);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--fg);
    margin: 0 0 0.75rem;
  }
  .work-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--fg-3);
    margin-bottom: 1.5rem;
  }
  .work-more {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--fg-2);
  }
  .work-card:hover .work-more { color: var(--accent-fg); }
  .work-more svg { transition: transform 0.25s ease; }
  .work-card:hover .work-more svg { transform: translateX(3px); }

  @media (min-width: 640px) {
    .works-grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
  }
  @media (min-width: 1280px) {
    .works-grid { grid-template-columns: 1fr 1fr 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-card, .tilt-l, .tilt-r { transform: none !important; }
    .work-card:hover { transform: none !important; }
    .work-more svg, .work-card:hover .work-more svg { transform: none; }
  }
</style>

<script>
  const grid = document.getElementById("works-grid");
  const filters = document.querySelectorAll<HTMLButtonElement>(".works-filter");
  if (grid && filters.length) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".work-item"));
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter;
        filters.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("is-active", active);
          b.setAttribute("aria-pressed", active ? "true" : "false");
        });
        cards.forEach((card) => {
          const show = cat === "All" || card.dataset.category === cat;
          card.hidden = !show;
        });
      });
    });
  }
</script>
