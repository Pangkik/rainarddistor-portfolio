---
import { works, categories } from "../../data/works";
import { sections } from "../../data/site";
import { buttons } from "../../data/site";
---

<section id="works" class="works">
  <div class="shell">
    <header class="works-head" data-reveal>
      <div class="works-rule"></div>
      <p class="eyebrow eyebrow--accent">{sections.works.eyebrow}</p>
      <h2 class="works-heading">
        SELECTED <span class="works-emphasis">WRITING</span>
      </h2>
    </header>

    {/* Filters — vanilla JS toggles, all visible with no JS */}
    <div class="works-filters" role="group" aria-label="Filter works by category" data-reveal>
      {categories.map((cat, i) => (
        <button
          type="button"
          class:list={["works-filter", { "is-active": i === 0 }]}
          data-filter={cat}
          aria-pressed={i === 0 ? "true" : "false"}
        >
          {cat}
        </button>
      ))}
    </div>

    <ol class="works-list" id="works-grid">
      {works.map((work) => (
        <li class="work-item" data-category={work.category} data-reveal>
          <a
            href={work.link}
            target="_blank"
            rel="noopener noreferrer"
            class="work-link"
          >
            <div class="work-meta">
              <span class="eyebrow eyebrow--accent">{work.category}</span>
              <span class="eyebrow work-date">{work.date}</span>
            </div>
            <div class="work-body">
              <h3 class="work-title">{work.title}</h3>
              <p class="work-desc">{work.description}</p>
              <span class="work-more">
                {buttons.readMore}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .works {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    background: var(--paper);
  }

  .works-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .works-rule {
    width: 3.5rem;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.75rem;
  }
  .works-heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin: 0.9rem 0 0;
    text-transform: none;
    font-variation-settings: "opsz" 72;
  }
  /* Keyword emphasis in the writing register: accent word + thin underline */
  .works-emphasis {
    color: var(--accent-ink);
    white-space: nowrap;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 0.05em;
  }

  .works-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .works-filter {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3-solid);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 100px;
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }
  .works-filter:hover {
    color: var(--ink);
    border-color: var(--line-strong);
  }
  .works-filter.is-active {
    color: var(--paper);
    background: var(--ink);
    border-color: var(--ink);
  }

  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .work-item {
    border-top: 1px solid var(--line);
  }
  .work-item:last-child { border-bottom: 1px solid var(--line); }
  .work-item[hidden] { display: none; }

  .work-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding: 2rem 0;
  }
  .work-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .work-date { color: var(--ink-3-solid); }

  .work-title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 460;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    text-transform: none;
    margin: 0 0 0.6rem;
    transition: color 0.3s ease;
    max-width: 24ch;
  }
  .work-link:hover .work-title { color: var(--accent-ink); }
  .work-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 1rem;
    max-width: 52ch;
  }
  .work-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .work-more svg { transition: transform 0.3s ease; }
  .work-link:hover .work-more svg { transform: translateX(4px); }

  @media (min-width: 768px) {
    .work-link {
      grid-template-columns: 14rem 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    .work-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
      padding-top: 0.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work-more svg,
    .work-link:hover .work-more svg { transform: none; }
  }
</style>

<script>
  const grid = document.getElementById("works-grid");
  const filters = document.querySelectorAll<HTMLButtonElement>(".works-filter");
  if (grid && filters.length) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>(".work-item"));
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter;
        filters.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("is-active", active);
          b.setAttribute("aria-pressed", active ? "true" : "false");
        });
        cards.forEach((card) => {
          const show = cat === "All" || card.dataset.category === cat;
          card.hidden = !show;
        });
      });
    });
  }
</script>
