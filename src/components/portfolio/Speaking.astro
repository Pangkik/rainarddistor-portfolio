---
import { Image } from "astro:assets";
import { engagements } from "../../data/speaking";
import { sections } from "../../data/site";
import { buttons } from "../../data/site";

import podium from "../../assets/portfolio/CYBERCON Day 3-191.jpg";
import flags from "../../assets/portfolio/CYBERCON Day 3-142.jpeg";
import dinner from "../../assets/portfolio/CYBERCON Network Dinner-115.jpg";
import ceremony from "../../assets/portfolio/IMG_7914.JPG";

// One photo per engagement, cycled. Alt text is descriptive (not visible copy).
const photos = [
  { src: podium, alt: "Speaking at a podium on the CYBERCON 2025 stage" },
  { src: flags, alt: "Standing before ASEAN member-state flags" },
  { src: dinner, alt: "Delegates at the CYBERCON 2025 networking dinner" },
  { src: ceremony, alt: "Receiving a certificate of recognition on stage" },
];
---

<section id="speaking" class="speaking">
  <div class="shell">
    <header class="speaking-head" data-reveal>
      <div class="speaking-rule"></div>
      <p class="eyebrow eyebrow--accent">{sections.speaking.eyebrow}</p>
      <h2 class="speaking-heading">
        ENGAGEMENTS & <span class="speaking-emphasis">TALKS</span>
      </h2>
    </header>

    <div class="speaking-grid">
      {engagements.map((eng, i) => (
        <a
          href={eng.url}
          target="_blank"
          rel="noopener noreferrer"
          class="speak-card"
          data-reveal
        >
          <figure class="speak-photo">
            <Image
              src={photos[i % photos.length].src}
              alt={photos[i % photos.length].alt}
              widths={[420, 720]}
              sizes="(min-width: 900px) 22rem, 90vw"
              loading="lazy"
            />
          </figure>
          <div class="speak-body">
            <div class="speak-meta">
              <span class="eyebrow eyebrow--accent">{eng.date}</span>
            </div>
            <h3 class="speak-event">{eng.event}</h3>
            <p class="speak-role">{eng.role}, <em>{eng.topic}</em></p>
            <p class="speak-desc">{eng.description}</p>
            <span class="speak-more">
              {buttons.viewMore}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .speaking {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    background: var(--paper-2);
  }

  .speaking-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .speaking-rule {
    width: 3.5rem;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.75rem;
  }
  .speaking-heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin: 0.9rem 0 0;
    text-transform: none;
    font-variation-settings: "opsz" 72;
  }
  .speaking-emphasis {
    color: var(--accent-ink);
    white-space: nowrap;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 0.05em;
  }

  .speaking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 6vw, 3.5rem);
  }

  .speak-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .speak-photo {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper-3);
  }
  .speak-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .speak-card:hover .speak-photo :global(img) { transform: scale(1.03); }

  .speak-body { display: flex; flex-direction: column; }
  .speak-meta { margin-bottom: 0.75rem; }
  .speak-event {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 460;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    text-transform: none;
    margin-bottom: 0.55rem;
    transition: color 0.3s ease;
  }
  .speak-card:hover .speak-event { color: var(--accent-ink); }
  .speak-role {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--accent-ink);
    margin-bottom: 0.75rem;
  }
  .speak-role em { font-style: italic; }
  .speak-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 1.2rem;
    max-width: 52ch;
  }
  .speak-more {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .speak-more svg { transition: transform 0.3s ease; }
  .speak-card:hover .speak-more svg { transform: translateX(4px); }

  @media (min-width: 900px) {
    .speaking-grid { grid-template-columns: 1fr 1fr; gap: clamp(3rem, 5vw, 4.5rem) 3rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .speak-card:hover .speak-photo :global(img) { transform: none; }
    .speak-more svg,
    .speak-card:hover .speak-more svg { transform: none; }
  }
</style>
