---
import { Image } from "astro:assets";
import { engagements } from "../../data/speaking";
import { sections } from "../../data/site";

import cagai from "../../assets/portfolio/IMG_7915.JPG";
import cybercon from "../../assets/portfolio/CYBERCON Day 3-191.jpg";
import ayfn from "../../assets/blog/dfuns 2025-10-20 200141.684.JPG";
import adse from "../../assets/portfolio/peek-pick-adse.jpg";

// Photo wired per event name.
const photoByEvent: Record<string, { src: ImageMetadata; alt: string } | null> = {
  "Use of AI in CagAI": {
    src: cagai,
    alt: "Rainard Distor speaking on the use of AI at CagAI",
  },
  "ASEAN-IPR Regional Conference on Cybersecurity": {
    src: cybercon,
    alt: "Rainard Distor presenting at the ASEAN-IPR Regional Conference on Cybersecurity 2025",
  },
  "AYFN Cultural Exchange Program (Autumn Japan Culture Camp)": {
    src: ayfn,
    alt: "Rainard Distor at the AYFN Autumn Japan Culture Camp in Osaka",
  },
  "ASEAN Data Science Explorers (ADSE) National Finals": {
    src: adse,
    alt: "Peek-Pick project title card from the ASEAN Data Science Explorers 2025 National Finals",
  },
};
---

<section id="speaking" class="block">
  <div class="shell">
    <div class="sec-head" data-reveal>
      <div>
        <h2 class="sec-title">
          <span class="sec-num">03</span><span class="sec-dash">—</span><span>speaking</span>
        </h2>
        <p class="sec-blurb">{sections.speaking.blurb}</p>
      </div>
    </div>

    <div class="speak-grid">
      {engagements.map((eng) => {
        const photo = photoByEvent[eng.event];
        return (
          <a href={eng.url} target="_blank" rel="noopener noreferrer" class="speak-card" data-reveal>
            {photo ? (
              <figure class="speak-photo">
                <Image
                  src={photo.src}
                  alt={photo.alt}
                  widths={[420, 720]}
                  sizes="(min-width: 720px) 24rem, 90vw"
                  loading="lazy"
                />
              </figure>
            ) : (
              <div class="speak-photo speak-photo--empty" aria-hidden="true">
                <span class="mono">{eng.date}</span>
              </div>
            )}
            <div class="speak-body">
              <span class="speak-date mono">{eng.date}</span>
              <h3 class="speak-event">{eng.event}</h3>
              <p class="speak-role">{eng.role}, <em>{eng.topic}</em></p>
              <p class="speak-desc">{eng.description}</p>
              <span class="speak-more mono">
                view
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M9 7h8v8"/></svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .speak-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3rem);
  }
  .speak-card { display: flex; flex-direction: column; gap: 1.25rem; }

  .speak-photo {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-3);
  }
  .speak-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .speak-card:hover .speak-photo :global(img) { transform: scale(1.03); }
  .speak-photo--empty {
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    background:
      repeating-linear-gradient(135deg, var(--bg-2) 0 12px, var(--bg-3) 12px 24px);
    color: var(--fg-3);
  }
  .speak-photo--empty span { font-size: var(--step--2); letter-spacing: 0.04em; }

  .speak-body { display: flex; flex-direction: column; }
  .speak-date {
    font-size: var(--step--2);
    color: var(--accent-fg);
    letter-spacing: 0.04em;
    margin-bottom: 0.6rem;
  }
  .speak-event {
    font-family: var(--font-body);
    font-size: var(--step-1);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--fg);
    margin-bottom: 0.5rem;
    transition: color 0.25s ease;
  }
  .speak-card:hover .speak-event { color: var(--accent-fg); }
  .speak-role {
    font-family: var(--font-body);
    font-size: var(--step-0);
    color: var(--fg-2);
    margin-bottom: 0.6rem;
  }
  .speak-role em { font-style: italic; color: var(--fg-3); }
  .speak-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--fg-3);
    margin-bottom: 1rem;
  }
  .speak-more {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--fg-2);
  }
  .speak-more svg { transition: transform 0.25s ease; }
  .speak-card:hover .speak-more svg { transform: translateX(3px); }

  @media (min-width: 720px) {
    .speak-grid { grid-template-columns: 1fr 1fr; gap: clamp(2.5rem, 4vw, 3.5rem) 2.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .speak-card:hover .speak-photo :global(img) { transform: none; }
    .speak-more svg, .speak-card:hover .speak-more svg { transform: none; }
  }
</style>
