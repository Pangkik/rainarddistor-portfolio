---
import { heroButtons } from "../../data/site";
---

<section class="seam">
  <div class="seam-inner" data-reveal>
    <span class="seam-rule" aria-hidden="true"></span>
    <a href="#works" class="btn-primary seam-cta">
      <span>{heroButtons.explore}</span>
      <svg class="seam-cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </a>
  </div>
</section>

<style>
  .seam {
    padding-top: clamp(4rem, 10vw, 7rem);
    padding-bottom: clamp(4rem, 10vw, 7rem);
    background: var(--paper);
    display: flex;
    justify-content: center;
  }

  .seam-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(2rem, 5vw, 3rem);
  }

  /* A quiet centered hairline, the editorial threshold */
  .seam-rule {
    width: 3.5rem;
    height: 1px;
    background: var(--line-strong);
  }

  .seam-cta {
    gap: 0.6rem;
  }
  .seam-cta-arrow {
    transition: transform 0.3s ease;
  }
  .seam-cta:hover .seam-cta-arrow { transform: translateY(3px); }

  @media (prefers-reduced-motion: reduce) {
    .seam-cta-arrow,
    .seam-cta:hover .seam-cta-arrow { transform: none; }
  }
</style>
