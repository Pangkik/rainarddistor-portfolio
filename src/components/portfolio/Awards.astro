---
import { awards } from "../../data/awards";
import { sections } from "../../data/site";
---

<section id="recognition" class="block">
  <div class="shell">
    <div class="sec-head" data-reveal>
      <div>
        <h2 class="sec-title">
          <span class="sec-num">04</span><span class="sec-dash">—</span><span>recognition</span>
        </h2>
        <p class="sec-blurb">{sections.awards.blurb}</p>
      </div>
    </div>

    <ol class="exp-list">
      {awards.map((award) => (
        <li class="exp-item" data-reveal>
          <a href={award.url} target="_blank" rel="noopener noreferrer" class="exp-row">
            <span class="exp-year mono">{award.year}</span>
            <span class="exp-main">
              <span class="exp-title">{award.title}</span>
              <span class="exp-desc">{award.description}</span>
            </span>
            <span class="exp-org mono">{award.org}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .exp-list { list-style: none; margin: 0; padding: 0; }
  .exp-item { border-top: 1px solid var(--line); }
  .exp-item:last-child { border-bottom: 1px solid var(--line); }

  .exp-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.75rem 0;
    transition: background 0.25s ease;
  }
  .exp-year {
    font-size: var(--step--1);
    color: var(--accent-fg);
    letter-spacing: 0.02em;
  }
  .exp-main { display: flex; flex-direction: column; gap: 0.4rem; }
  .exp-title {
    font-family: var(--font-body);
    font-size: var(--step-1);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--fg);
    transition: color 0.25s ease;
  }
  .exp-row:hover .exp-title { color: var(--accent-fg); }
  .exp-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--fg-3);
    max-width: 58ch;
  }
  .exp-org {
    font-size: var(--step--1);
    color: var(--fg-3);
    letter-spacing: 0.01em;
  }

  @media (min-width: 768px) {
    .exp-row {
      grid-template-columns: 5rem 1fr 16rem;
      gap: 2rem;
      align-items: baseline;
    }
    .exp-org { text-align: right; }
  }
</style>
