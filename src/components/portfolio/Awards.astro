---
import { awards } from "../../data/awards";
import { sections } from "../../data/site";
import { buttons } from "../../data/site";
---

<section id="awards" class="awards">
  <div class="shell">
    <header class="awards-head" data-reveal>
      <div class="awards-rule"></div>
      <p class="eyebrow eyebrow--accent">{sections.awards.eyebrow}</p>
      <h2 class="awards-heading">
        AWARDS & <span class="awards-emphasis">SCHOLARSHIPS</span>
      </h2>
    </header>

    <ol class="awards-list">
      {awards.map((award) => (
        <li class="award-item" data-reveal>
          <a
            href={award.url}
            target="_blank"
            rel="noopener noreferrer"
            class="award-link"
          >
            <span class="eyebrow award-year">{award.year}</span>
            <div class="award-body">
              <h3 class="award-title">{award.title}</h3>
              <p class="award-org">{award.org}</p>
              <p class="award-desc">{award.description}</p>
              <span class="award-more">
                {buttons.viewMore}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .awards {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    background: var(--paper);
  }

  .awards-head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }
  .awards-rule {
    width: 3.5rem;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1.75rem;
  }
  .awards-heading {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin: 0.9rem 0 0;
    text-transform: none;
    font-variation-settings: "opsz" 72;
  }
  .awards-emphasis {
    color: var(--accent-ink);
    white-space: nowrap;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 0.05em;
  }

  .awards-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
  }
  .award-item {
    border-top: 1px solid var(--line);
  }
  .award-item:last-child { border-bottom: 1px solid var(--line); }

  .award-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
    padding: 2rem 0;
  }
  .award-year {
    color: var(--accent-ink);
    padding-top: 0.35rem;
  }
  .award-title {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 460;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    text-transform: none;
    margin-bottom: 0.4rem;
    transition: color 0.3s ease;
  }
  .award-link:hover .award-title { color: var(--accent-ink); }
  .award-org {
    font-family: var(--font-body);
    font-size: var(--step-0);
    font-weight: 560;
    color: var(--ink-2);
    margin-bottom: 0.7rem;
  }
  .award-desc {
    font-family: var(--font-body);
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 1rem;
    max-width: 52ch;
  }
  .award-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 560;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-ink);
  }
  .award-more svg { transition: transform 0.3s ease; }
  .award-link:hover .award-more svg { transform: translateX(4px); }

  @media (min-width: 768px) {
    .award-link {
      grid-template-columns: 8rem 1fr;
      gap: 2.5rem;
      align-items: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .award-more svg,
    .award-link:hover .award-more svg { transform: none; }
  }
</style>
