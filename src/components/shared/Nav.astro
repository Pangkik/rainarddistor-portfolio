---
import { nav, heroButtons } from "../../data/site";

// Contact becomes the single filled button (anything-reference pattern).
const contactItem = nav.items.find((i) => i.href === "#contact");
const linkItems = nav.items.filter((i) => i.href !== "#contact");
---

<header class="site-nav" id="site-header">
  <nav class="shell nav-inner">
    <a href="/" class="nav-logo">
      {nav.logo.replace(/\.$/, "")}<span class="nav-dot">.</span>
    </a>

    <div class="nav-desktop">
      <ul class="nav-links">
        {linkItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>

      <div class="js-only">
        <div class="search-wrapper">
          <input
            type="text"
            id="pagefind-input"
            class="search-input"
            placeholder=""
            aria-label="Search"
          />
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <div id="search-results" class="search-results"></div>
        </div>
      </div>

      {contactItem && (
        <a href={contactItem.href} class="btn-primary nav-cta">
          {heroButtons.contact}
        </a>
      )}
    </div>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" id="mobile-menu-btn">
      <span></span><span></span>
    </button>
  </nav>

  <div id="mobile-menu" class="nav-mobile hidden">
    <div class="shell js-only nav-mobile-search">
      <div class="search-wrapper">
        <input
          type="text"
          id="pagefind-input-mobile"
          class="search-input"
          placeholder=""
          aria-label="Search"
        />
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <div id="search-results-mobile" class="search-results"></div>
      </div>
    </div>
    <ul class="shell nav-mobile-list">
      {nav.items.map((item) => (
        <li>
          <a href={item.href} class="nav-mobile-link">{item.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 78%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: color 0.35s ease;
  }

  .nav-dot {
    color: var(--accent-ink);
    transition: color 0.35s ease;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2.25rem;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 460;
    letter-spacing: 0.01em;
    color: var(--ink-2);
    position: relative;
    transition: color 0.25s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s ease;
  }

  .nav-link:hover { color: var(--ink); }
  .nav-link:hover::after { transform: scaleX(1); }

  .js-only {
    display: none;
  }
  :global(.js) .js-only {
    display: block;
  }

  .nav-mobile-search {
    padding-top: 1.25rem;
  }
  .nav-mobile-search .search-wrapper,
  .nav-mobile-search .search-input {
    width: 100%;
  }
  .nav-mobile-search .search-results {
    left: 0;
    right: 0;
    min-width: 0;
  }

  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-input {
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: 20px;
    padding: 0.5rem 0.75rem 0.5rem 2.2rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--ink);
    width: 160px;
    outline: none;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }
  .search-input::placeholder {
    color: var(--ink-3-solid);
  }
  .search-input:focus {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--paper) 98%, transparent);
  }

  .search-icon {
    position: absolute;
    left: 0.65rem;
    color: var(--ink-3-solid);
    pointer-events: none;
    transition: color 0.25s ease;
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: auto;
    right: 0;
    min-width: 320px;
    margin-top: 0.5rem;
    background: var(--paper-2);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    max-height: 320px;
    overflow-y: auto;
    display: none;
    z-index: 1000;
  }
  .search-results.active {
    display: block;
  }

  /* Injected via innerHTML at runtime, so they never get Astro's scope
     attribute — these must stay global to apply. */
  :global(.search-result-item) {
    padding: 0.85rem;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    display: block;
    transition: background 0.2s ease;
  }

  :global(.search-result-item:hover) {
    background: var(--paper-3);
  }

  :global(.search-result-title) {
    font-family: var(--font-display);
    font-size: var(--step--1);
    font-weight: 460;
    color: var(--ink);
    margin: 0 0 0.25rem;
  }

  :global(.search-result-excerpt) {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--ink-3-solid);
    margin: 0;
    line-height: 1.4;
  }

  :global(.search-result-excerpt mark) {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--ink);
    border-radius: 2px;
  }

  .nav-cta {
    padding: 0.55rem 1.15rem;
    transition: background 0.35s ease, border-color 0.35s ease, color 0.35s ease;
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.25s ease;
  }
  .nav-toggle span {
    display: block;
    height: 1.5px;
    width: 1.35rem;
    background: var(--ink);
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.35s ease;
  }

  .nav-toggle[aria-expanded="true"] span:first-child { transform: translateY(3.25px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:last-child { transform: translateY(-3.25px) rotate(-45deg); }

  .nav-mobile {
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--paper) 96%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  .nav-mobile.hidden { display: none; }
  .nav-mobile-list {
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 1rem;
    padding-bottom: 1.5rem;
  }
  .nav-mobile-link {
    display: block;
    padding: 0.6rem 0;
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 460;
    color: var(--ink-2);
    border-bottom: 1px solid var(--line);
    transition: color 0.25s ease, border-color 0.35s ease;
  }

  .nav-mobile-link:hover { color: var(--accent-ink); }

  @media (min-width: 768px) {
    .nav-inner { height: 5rem; }
    .nav-logo { font-size: 1.5rem; }
    .nav-desktop { display: flex; }
    .nav-toggle { display: none; }
    .nav-mobile { display: none !important; }
  }
</style>

<script>
  // Menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", open ? "false" : "true");
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  // Pagefind search (desktop nav + mobile menu share one module instance)
  let pagefind: any;

  const bindSearch = (input: HTMLInputElement | null, results: HTMLElement | null) => {
    if (!input || !results) return;
    let debounceTimer: ReturnType<typeof setTimeout>;

    // Lazy load pagefind on first focus
    input.addEventListener("focus", async () => {
      if (!pagefind) {
        try {
          pagefind = await import("/pagefind/pagefind.js");
        } catch (e) {
          console.error("Pagefind failed to load");
        }
      }
    });

    // Search on input with debounce
    input.addEventListener("input", (e: Event) => {
      const query = (e.target as HTMLInputElement).value;
      clearTimeout(debounceTimer);

      if (!query.trim()) {
        results.classList.remove("active");
        return;
      }

      debounceTimer = setTimeout(async () => {
        if (!pagefind) return;
        try {
          const searched = await pagefind.search(query);

          if (searched.results.length === 0) {
            results.innerHTML = "";
            results.classList.remove("active");
            return;
          }

          const loaded = await Promise.all(
            searched.results.slice(0, 5).map((result: any) => result.data())
          );
          results.innerHTML = loaded
            .map((data: any) => {
              const title = data.meta?.title || "Untitled";
              const excerpt = data.excerpt || "";
              return `
                <a href="${data.url}" class="search-result-item">
                  <p class="search-result-title">${title}</p>
                  <p class="search-result-excerpt">${excerpt}</p>
                </a>
              `;
            })
            .join("");

          results.classList.add("active");
        } catch (e) {
          console.error("Search error:", e);
        }
      }, 150);
    });

    // Close on escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        results.classList.remove("active");
        input.blur();
      }
    });

    // Close on click outside
    document.addEventListener("click", (e) => {
      if (!input.contains(e.target as Node) && !results.contains(e.target as Node)) {
        results.classList.remove("active");
      }
    });
  };

  bindSearch(
    document.getElementById("pagefind-input") as HTMLInputElement | null,
    document.getElementById("search-results")
  );
  bindSearch(
    document.getElementById("pagefind-input-mobile") as HTMLInputElement | null,
    document.getElementById("search-results-mobile")
  );
</script>
