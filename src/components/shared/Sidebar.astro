---
import { contactLinks } from "../../data/site";

// Section nav. Each entry: a small monochrome icon (inline SVG) + lowercase label.
const navItems = [
  { label: "writing", href: "#writing", icon: "pen" },
  { label: "about", href: "#about", icon: "user" },
  { label: "works", href: "#works", icon: "layers" },
  { label: "speaking", href: "#speaking", icon: "mic" },
  { label: "recognition", href: "#recognition", icon: "award" },
  { label: "contact", href: "#contact", icon: "mail" },
  { label: "blog", href: "/blog", icon: "book" },
];
---

<header class="sidebar" id="sidebar">
  {/* Mobile top bar (below 1024px): name + hamburger */}
  <div class="sidebar-bar">
    <a href="/" class="sidebar-name mono">Rainard Distor</a>
    <button
      class="sidebar-toggle"
      id="sidebar-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="sidebar-body"
    >
      <span></span><span></span>
    </button>
  </div>

  <div class="sidebar-body" id="sidebar-body">
    <a href="/" class="sidebar-name-lg mono">Rainard Distor</a>

    <nav class="sidebar-nav" aria-label="Sections">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="sidebar-link" data-nav-link>
              <span class="sidebar-ico" aria-hidden="true">
                {item.icon === "pen" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 20h9" stroke-linecap="round"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" stroke-linejoin="round"/></svg>
                )}
                {item.icon === "user" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0" stroke-linecap="round"/></svg>
                )}
                {item.icon === "layers" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="m12 3 9 5-9 5-9-5 9-5Z"/><path d="m3 13 9 5 9-5"/></svg>
                )}
                {item.icon === "mic" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0 0 14 0M12 18v3"/></svg>
                )}
                {item.icon === "award" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="m8.5 14-1.5 7 5-3 5 3-1.5-7"/></svg>
                )}
                {item.icon === "mail" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                )}
                {item.icon === "book" && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2Z"/><path d="M19 19v2"/></svg>
                )}
              </span>
              <span class="sidebar-label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Command-palette hint (dormant entry point; wired in a later phase) */}
    <button class="sidebar-kbd" id="cmdk-hint" type="button" aria-label="Open search">
      <span class="sidebar-kbd-keys mono"><kbd>⌘</kbd><kbd>K</kbd></span>
      <span class="sidebar-kbd-label">search</span>
    </button>

    {/* Theme toggle: system / light / dark */}
    <div class="sidebar-theme" role="group" aria-label="Theme">
      <button type="button" class="theme-btn" data-theme-set="system" aria-label="System theme" title="System">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4" stroke-linecap="round"/></svg>
      </button>
      <button type="button" class="theme-btn" data-theme-set="light" aria-label="Light theme" title="Light">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
      <button type="button" class="theme-btn" data-theme-set="dark" aria-label="Dark theme" title="Dark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.5 6.5 0 0 0 9.8 9.8Z"/></svg>
      </button>
    </div>

    {/* Contact at the very bottom */}
    <div class="sidebar-foot">
      <p class="sidebar-foot-line">Say hello.</p>
      <a href={`mailto:${contactLinks.email}`} class="sidebar-email mono">{contactLinks.email}</a>
    </div>
  </div>
</header>

<style>
  .sidebar {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }

  /* Mobile top bar */
  .sidebar-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
    padding-inline: 1.5rem;
  }
  .sidebar-name {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .sidebar-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0;
  }
  .sidebar-toggle span {
    display: block;
    height: 1.5px;
    width: 1.35rem;
    background: var(--fg);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .sidebar-toggle[aria-expanded="true"] span:first-child { transform: translateY(3.25px) rotate(45deg); }
  .sidebar-toggle[aria-expanded="true"] span:last-child { transform: translateY(-3.25px) rotate(-45deg); }

  /* Body: drawer on mobile, fixed column on desktop */
  .sidebar-body {
    display: none;
    flex-direction: column;
    padding: 1.5rem 1.5rem 2rem;
    border-top: 1px solid var(--line);
  }
  .sidebar-body.is-open { display: flex; }

  .sidebar-name-lg {
    display: none;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 2.5rem;
  }

  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.4rem;
    border-radius: var(--radius);
    color: var(--fg-3);
    transition: color 0.2s ease, background 0.2s ease;
  }
  .sidebar-link:hover { color: var(--fg); background: var(--bg-2); }
  .sidebar-link.is-active { color: var(--fg); }
  .sidebar-ico {
    display: inline-flex;
    width: 1.1rem;
    height: 1.1rem;
    flex: none;
  }
  .sidebar-ico svg { width: 100%; height: 100%; }
  .sidebar-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: lowercase;
  }

  .sidebar-kbd {
    margin-top: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.4rem;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--fg-3);
    transition: color 0.2s ease;
  }
  .sidebar-kbd:hover { color: var(--fg); }
  .sidebar-kbd-keys { display: inline-flex; gap: 0.25rem; }
  .sidebar-kbd kbd {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1;
    padding: 0.2rem 0.35rem;
    border: 1px solid var(--line-strong);
    border-radius: 4px;
    color: var(--fg-2);
  }
  .sidebar-kbd-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.02em;
  }

  .sidebar-theme {
    margin-top: 1.5rem;
    display: inline-flex;
    gap: 0.25rem;
    padding: 0.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    width: fit-content;
  }
  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 1.9rem;
    background: none;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
    color: var(--fg-3);
    transition: color 0.2s ease, background 0.2s ease;
  }
  .theme-btn svg { width: 1rem; height: 1rem; }
  .theme-btn:hover { color: var(--fg); }
  .theme-btn.is-active { color: var(--fg); background: var(--bg-3); }

  .sidebar-foot { margin-top: 2.25rem; }
  .sidebar-foot-line {
    font-family: var(--font-body);
    font-size: var(--step--1);
    color: var(--fg-3);
    margin-bottom: 0.35rem;
  }
  .sidebar-email {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--fg-2);
    word-break: break-all;
    transition: color 0.2s ease;
  }
  .sidebar-email:hover { color: var(--accent-fg); }

  /* Desktop: fixed left rail */
  @media (min-width: 1024px) {
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--sidebar-w);
      border-bottom: 0;
      border-right: 1px solid var(--line);
      z-index: 40;
      display: flex;
      flex-direction: column;
    }
    .sidebar-bar { display: none; }
    .sidebar-body {
      display: flex !important;
      flex: 1;
      padding: 2.25rem 1.75rem 2rem;
      border-top: 0;
      overflow-y: auto;
    }
    .sidebar-name-lg { display: block; }
    .sidebar-foot { margin-top: auto; padding-top: 2.5rem; }
  }
</style>

<script>
  // Mobile drawer toggle
  const toggle = document.getElementById("sidebar-toggle");
  const body = document.getElementById("sidebar-body");
  toggle?.addEventListener("click", () => {
    const open = body?.classList.toggle("is-open");
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  });
  body?.querySelectorAll("[data-nav-link]").forEach((link) => {
    link.addEventListener("click", () => {
      if (window.innerWidth < 1024) {
        body.classList.remove("is-open");
        toggle?.setAttribute("aria-expanded", "false");
      }
    });
  });

  // Scroll-spy: mark the active section link
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'));
  const map = new Map<string, HTMLAnchorElement>();
  links.forEach((l) => {
    const href = l.getAttribute("href") || "";
    if (href.startsWith("#")) map.set(href.slice(1), l);
  });
  const targets = Array.from(map.keys())
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  if (targets.length && "IntersectionObserver" in window) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove("is-active"));
            const active = map.get(e.target.id);
            active?.classList.add("is-active");
          }
        });
      },
      { rootMargin: "-45% 0px -50% 0px", threshold: 0 }
    );
    targets.forEach((t) => spy.observe(t));
  }

  // Theme toggle: system / light / dark. Persisted in localStorage.
  const KEY = "theme";
  const themeBtns = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-theme-set]"));
  const mql = window.matchMedia("(prefers-color-scheme: dark)");

  const resolve = (choice: string) =>
    choice === "system" ? (mql.matches ? "dark" : "light") : choice;

  const apply = (choice: string) => {
    document.documentElement.setAttribute("data-theme", resolve(choice));
    themeBtns.forEach((b) =>
      b.classList.toggle("is-active", b.dataset.themeSet === choice)
    );
  };

  const stored = localStorage.getItem(KEY) || "system";
  apply(stored);

  themeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const choice = btn.dataset.themeSet || "system";
      localStorage.setItem(KEY, choice);
      apply(choice);
    });
  });

  mql.addEventListener("change", () => {
    if ((localStorage.getItem(KEY) || "system") === "system") apply("system");
  });
</script>
